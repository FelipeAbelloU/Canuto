# Entorno virtual
venv/
.venv/
# entorno aparte para el OCR docling (workstation)
venv-docling/

# Checkpoints del modelo (3 GB — demasiado grandes para GitHub)
data/checkpoints/

# Corpus PDF de SIRIUS (~5 GB — se transfiere aparte por USB/disco, no por git)
PDF/

# Textos extraídos (se regeneran con scripts/extract_text.py)
data/extracted/

# Notas de trabajo personales (no forman parte del proyecto)
retomar.txt

# Dataset y splits (se regeneran con build_dataset.py / split_dataset.py / evaluate.py)
data/dataset/dataset_alpaca.json
data/dataset/train.json
data/dataset/test.json
data/dataset/resultados_evaluacion.json

# Cola de OCR para la workstation (se regenera al correr extract_text.py)
data/_ocr_queue.txt

# Cache de Python
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
*.egg-info/

# Variables de entorno
.env
.env.local

# Artefactos de descarga HuggingFace
*.incomplete
*.lock

# Archivos de sistema
.DS_Store
Thumbs.db
desktop.ini

# Logs y resultados de pruebas (se regeneran)
*.log
data/test_results.txt

# Vector store (no se usa en este proyecto)
data/vectorstore/

# IDEs
.idea/

# Configuración local del editor (rutas específicas de la máquina)
.claude/

# Notas de trabajo y contexto local — no forman parte del proyecto entregable
memory/
CLAUDE.md
notas y ayudas/prompts tesis.txt

# Mockup React (referencia de diseño — código fuente de Figma Make, no es parte del proyecto)
mockup_chatbot/

# Archivos de error Django subidos por accidente
RecursionError*.pdf

# Cookies y logs temporales de sesión
cookies.txt
srv*.txt
ui_server*.log
